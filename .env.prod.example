# ─── Base de données (MariaDB partagée 192.168.1.95) ────────────────────────
MARIADB_USER=admin
MARIADB_PASSWORD=changeme_mariadb_password

# ─── Keycloak (auth.neolegal.fr) ────────────────────────────────────────────
# Secret du client namorama-api (Keycloak > Clients > namorama-api > Credentials)
KEYCLOAK_SECRET=secret-tres-confidentiel-123

# ─── Stripe — Price IDs des packs ────────────────────────────────────────────
# Créer 3 produits one-time dans Stripe Dashboard, copier les Price IDs ici
STRIPE_PACK_DECOUVERTE_PRICE_ID=price_...   # 9 € / 500 crédits
STRIPE_PACK_PRO_PRICE_ID=price_...          # 19 € / 2000 crédits
STRIPE_PACK_MAX_PRICE_ID=price_...          # 29 € / 5000 crédits

# ─── URLs publiques ──────────────────────────────────────────────────────────
API_URL=https://namorama-api.neolegal.fr
KEYCLOAK_URL=https://auth.neolegal.fr
FRONTEND_URL=https://namorama.neolegal.fr

# ─── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_ESSENTIAL_PRICE_ID=price_...
STRIPE_PACK_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...
